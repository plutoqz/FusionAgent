GEOFUSION_KG_BACKEND=memory
GEOFUSION_LLM_PROVIDER=mock
GEOFUSION_LLM_BASE_URL=http://fast.jnm.lol/v1
GEOFUSION_LLM_MODEL=gpt-5.4-mini
GEOFUSION_CELERY_EAGER=1
GEOFUSION_CELERY_BROKER=redis://localhost:6379/0
GEOFUSION_CELERY_BACKEND=redis://localhost:6379/0
GEOFUSION_NEO4J_URI=bolt://localhost:7687
GEOFUSION_NEO4J_USER=neo4j
GEOFUSION_NEO4J_PASSWORD=change-me
# Optional: leave blank to auto-detect the current Neo4j home database.
GEOFUSION_NEO4J_DATABASE=
GEOFUSION_SCHEDULED_INTERVAL_SECONDS=3600
GEOFUSION_SCHEDULED_RUNS=[]
# Default storage roots. Leave blank to use the engineering defaults:
# data repository D:\fyx\任务, downloads D:\fyx\任务\fusionagent_downloads,
# run outputs D:\fyx\data\fusionagent_runs, scenario outputs D:\fyx\data\fusionagent_scenarios.
GEOFUSION_DATA_REPOSITORY_ROOT=
GEOFUSION_DOWNLOAD_ROOT=
GEOFUSION_OUTPUT_ROOT=
GEOFUSION_RUNS_ROOT=
GEOFUSION_SCENARIO_OUTPUT_ROOT=
# Optional building height raster acquisition. Local paths may be files or directories.
# Source-specific vars override the mapping vars. URL downloads obey the rapid-response budget.
GEOFUSION_HEIGHT_RASTER_MAX_SECONDS=30
GEOFUSION_HEIGHT_RASTER_PATHS=
GEOFUSION_HEIGHT_RASTER_URLS=
GEOFUSION_HEIGHT_RASTER_OPEN_BUILDINGS_2_5D_PATH=
GEOFUSION_HEIGHT_RASTER_3D_GLOBFP_PATH=
GEOFUSION_HEIGHT_RASTER_GOOGLE_PATH=
GEOFUSION_HEIGHT_RASTER_LOCAL_PATH=
GEOFUSION_HEIGHT_RASTER_OPEN_BUILDINGS_2_5D_URL=
GEOFUSION_HEIGHT_RASTER_3D_GLOBFP_URL=
GEOFUSION_HEIGHT_RASTER_GOOGLE_URL=
GEOFUSION_HEIGHT_RASTER_LOCAL_URL=
